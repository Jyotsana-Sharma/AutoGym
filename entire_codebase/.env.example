# SparkyFitness ML System — Environment Variables
# Copy this file to .env and fill in your values before running `make setup`

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=sparky_pass

# ---------------------------------------------------------------------------
# Chameleon OpenStack Swift (object storage for training data)
# Get these from: https://chi.tacc.chameleoncloud.org → Identity → Application Credentials
# ---------------------------------------------------------------------------
OS_AUTH_URL=https://chi.tacc.chameleoncloud.org:5000/v3
OS_APPLICATION_CREDENTIAL_ID=your_credential_id_here
OS_APPLICATION_CREDENTIAL_SECRET=your_credential_secret_here
OS_REGION_NAME=CHI@TACC

# ---------------------------------------------------------------------------
# MLflow
# ---------------------------------------------------------------------------
# Set to http://mlflow:5000 when running inside Docker Compose
# Set to your Chameleon instance URL when running on Chameleon
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_MODEL_NAME=sparky-ranker

# ---------------------------------------------------------------------------
# Training
# ---------------------------------------------------------------------------
NDCG_THRESHOLD=0.55
IMPROVEMENT_THRESHOLD=0.01
TRAIN_CSV=/training-data/train.csv
VAL_CSV=/training-data/val.csv
TEST_CSV=/training-data/test.csv
MODEL_EXPORT_PATH=/models/xgboost_ranker.json

# ---------------------------------------------------------------------------
# Serving
# ---------------------------------------------------------------------------
MODEL_FALLBACK_PATH=/models/xgboost_ranker.json
LOG_PREDICTIONS=true
MODEL_POLL_INTERVAL_SEC=60

# ---------------------------------------------------------------------------
# Drift Monitor
# ---------------------------------------------------------------------------
DRIFT_THRESHOLD=0.05
CHECK_INTERVAL_SECONDS=300
LOOKBACK_HOURS=24
MIN_SAMPLES_FOR_DRIFT=100
RETRAIN_WEBHOOK_URL=http://retrain-api:8080/trigger

# ---------------------------------------------------------------------------
# Monitoring
# ---------------------------------------------------------------------------
GRAFANA_PASSWORD=sparky_admin
ROLLBACK_WEBHOOK_TOKEN=change_me_before_enabling_alert_rollbacks
ROLLBACK_ALERT_NAMES=HighErrorRate

# ---------------------------------------------------------------------------
# SparkyFitness app integration
# ---------------------------------------------------------------------------
SPARKY_FITNESS_DB_NAME=sparkyfitness_db
SPARKY_FITNESS_DB_USER=sparky
SPARKY_FITNESS_DB_PASSWORD=sparky_fit_pass
SPARKY_FITNESS_APP_DB_USER=sparkyapp
SPARKY_FITNESS_APP_DB_PASSWORD=sparky_app_pass
SPARKY_FITNESS_API_ENCRYPTION_KEY=changeme_32char_key_for_prod_use!
BETTER_AUTH_SECRET=changeme_better_auth_secret_for_production
SPARKY_FITNESS_FRONTEND_URL=http://localhost:3004
SPARKY_FITNESS_DISABLE_SIGNUP=false
SPARKY_FITNESS_ADMIN_EMAIL=
SPARKY_FITNESS_LOG_LEVEL=info
ALLOW_PRIVATE_NETWORK_CORS=false
SPARKY_FITNESS_EXTRA_TRUSTED_ORIGINS=
ML_RECOMMENDATION_URL=http://sparky-serving:8000
ML_MODEL_NAME=sparky-ranker

# ---------------------------------------------------------------------------
# GitHub Actions Secrets (set in repo Settings → Secrets, not in this file)
# ---------------------------------------------------------------------------
# MLFLOW_TRACKING_URI   — Chameleon instance URL
# POSTGRES_PASSWORD     — Production DB password
# SERVING_URL           — Production serving URL
# SLACK_WEBHOOK_URL     — Optional Slack alerting
