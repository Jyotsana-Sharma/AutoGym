# SparkyFitness Application — Environment Variables
# Copied to SparkyFitness/.env by scripts/setup-sparkyfitness.sh
#
# For local development the defaults below work out of the box.
# Change secrets before deploying to production.

# ── Database ──────────────────────────────────────────────────────────────
SPARKY_FITNESS_DB_NAME=sparkyfitness_db
SPARKY_FITNESS_DB_USER=sparky
SPARKY_FITNESS_DB_PASSWORD=sparky_fit_pass
SPARKY_FITNESS_DB_PORT=5432
SPARKY_FITNESS_DB_HOST=sparkyfitness-db

# App-level DB user (used by the server to connect with least-privilege role)
SPARKY_FITNESS_APP_DB_USER=sparkyapp
SPARKY_FITNESS_APP_DB_PASSWORD=sparky_app_pass

# ── Security (change these in production) ─────────────────────────────────
# Must be at least 32 characters
SPARKY_FITNESS_API_ENCRYPTION_KEY=changeme_32char_key_for_prod_use!
BETTER_AUTH_SECRET=changeme_better_auth_secret_for_production

# ── Application URLs ───────────────────────────────────────────────────────
SPARKY_FITNESS_FRONTEND_URL=http://localhost:3004

# ── ML Recommendation System ──────────────────────────────────────────────
# Points to the sparky-serving container on the shared sparky-net network
ML_RECOMMENDATION_URL=http://sparky-serving:8000
ML_MODEL_NAME=sparky-ranker

# ── Optional features ─────────────────────────────────────────────────────
SPARKY_FITNESS_DISABLE_SIGNUP=false
SPARKY_FITNESS_ADMIN_EMAIL=
SPARKY_FITNESS_LOG_LEVEL=info
ALLOW_PRIVATE_NETWORK_CORS=false
SPARKY_FITNESS_EXTRA_TRUSTED_ORIGINS=

# ── Email (optional — leave blank to disable) ─────────────────────────────
SPARKY_FITNESS_EMAIL_HOST=
SPARKY_FITNESS_EMAIL_PORT=
SPARKY_FITNESS_EMAIL_SECURE=
SPARKY_FITNESS_EMAIL_USER=
SPARKY_FITNESS_EMAIL_PASS=
SPARKY_FITNESS_EMAIL_FROM=

# ── Garmin microservice (optional) ────────────────────────────────────────
GARMIN_MICROSERVICE_URL=http://sparkyfitness-garmin:8000
