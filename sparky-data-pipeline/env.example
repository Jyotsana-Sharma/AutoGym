# Chameleon Cloud OpenStack credentials
# Get these from: CHI@TACC → Identity → Application Credentials → Download OpenStack RC File
# Or fill manually from your Chameleon project settings

OS_AUTH_URL=https://chi.tacc.chameleoncloud.org:5000/v3
OS_USERNAME=your-chameleon-username
OS_PASSWORD=your-chameleon-password
OS_PROJECT_NAME=CHI-XXXXXX
OS_PROJECT_DOMAIN_NAME=default
OS_USER_DOMAIN_NAME=default
OS_REGION_NAME=CHI@TACC

# PostgreSQL
POSTGRES_PASSWORD=sparky_pass

# Git commit (auto-filled by Makefile)
GIT_COMMIT=unknown
